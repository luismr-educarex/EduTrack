.env
.env.*
!.env.example
/aulatrack/

# Optional: if using TypeScript
*.tsbuildinfo

# Optional: if using testing tools
coverage/
jest-test-results.json

# Optional: if using IDEs
.vscode/
.idea/

# Optional: if using TurboRepo or monorepo
turbo/
